APP_NAME=fullstack-app
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORE_DOMAIN_SINGULAR=Project
CORE_DOMAIN_PLURAL=Projects
PLATFORM_DEFAULT_MODULE_PACK=full_platform

DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app_db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_EMAIL_QUEUE=email
CELERY_RESULT_EXPIRES_SECONDS=3600

JWT_SECRET=replace-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false
ADMIN_SIGNUP_INVITE_CODE=

VERIFICATION_TOKEN_TTL=86400
PASSWORD_RESET_TOKEN_TTL=3600

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=true

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
OTLP_ENDPOINT=
OTLP_INSECURE=true

STORAGE_BUCKET=app-assets
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_USE_SSL=false
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/app-assets
STORAGE_AUTO_CREATE_BUCKET=true
STORAGE_PUBLIC_READ=true
STORAGE_AVATAR_MAX_BYTES=5242880

COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
COPERNICUS_CATALOG_URL=https://sh.dataspace.copernicus.eu/api/v1/catalog/1.0.0/search
COPERNICUS_PROCESS_URL=https://sh.dataspace.copernicus.eu/api/v1/process
COPERNICUS_DEFAULT_COLLECTION=sentinel-2-l2a
COPERNICUS_DEFAULT_COUNTRY=BE
COPERNICUS_DEFAULT_CLOUD_THRESHOLD=25
COPERNICUS_HTTP_TIMEOUT_SECONDS=45
COPERNICUS_TOKEN_SAFETY_MARGIN_SECONDS=60
COPERNICUS_SEARCH_CACHE_TTL_SECONDS=900
COPERNICUS_RENDER_CACHE_TTL_SECONDS=1800
COPERNICUS_ASSET_CACHE_TTL_SECONDS=1800
COPERNICUS_CACHE_BBOX_PRECISION=4
